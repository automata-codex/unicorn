{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "html": {
    "formatter": {
      "indentScriptAndStyle": true
    }
  },
  "linter": {
    "enabled": false
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              { "source": ":NODE:", "type": false },
              { "source": ":PACKAGE:", "type": false },
              ":BLANK_LINE:",
              { "source": "@uv/**", "type": false },
              ":BLANK_LINE:",
              { "source": "../**", "type": false },
              ":BLANK_LINE:",
              { "source": "./**", "type": false },
              { "source": "./", "type": false },
              ":BLANK_LINE:",
              ":TYPE:"
            ]
          }
        }
      }
    }
  },
  "files": {
    "includes": ["**"]
  }
}
