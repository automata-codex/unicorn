{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"sourceMap": true,
		"verbatimModuleSyntax": true,
		"types": ["svelte", "vite/client"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
